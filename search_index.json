---
name: Search
description: Search P2PTalk Wiki
---
<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>搜索 — P2PTalk Wiki</title>
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --border: #30363d;
    --text: #e6edf3;
    --muted: #8b949e;
    --accent: #e94560;
    --blue: #58a6ff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }
  .back { color: var(--muted); font-size: 0.85rem; margin-bottom: 1rem; display: inline-block; }
  .back:hover { color: var(--text); }
  h1 { font-size: 1.2rem; margin-bottom: 1rem; }
  input {
    width: 100%; padding: 12px 16px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); font-size: 1rem;
    outline: none; margin-bottom: 1rem;
  }
  input:focus { border-color: var(--accent); }
  .results { display: flex; flex-direction: column; gap: 0.6rem; }
  .result {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.9rem 1rem;
    text-decoration: none; color: var(--text);
    transition: border-color 0.15s;
  }
  .result:hover { border-color: var(--muted); text-decoration: none; }
  .result-title { color: var(--blue); font-weight: 500; margin-bottom: 0.3rem; }
  .result-cat { font-size: 0.72rem; color: var(--muted); margin-bottom: 0.3rem; }
  .result-text { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }
  .result-text em { color: var(--text); font-style: normal; background: rgba(233,69,96,0.2); padding: 0 2px; border-radius: 2px; }
  .empty { color: var(--muted); text-align: center; padding: 2rem; font-size: 0.9rem; }
  .hint { color: var(--muted); font-size: 0.8rem; margin-bottom: 1rem; }
</style>
</head>
<body>
<a class="back" href="index.html">← 返回总览</a>
<h1>🔍 搜索</h1>
<input type="text" id="q" placeholder="搜索概念、人名、关键词…" autofocus>
<div class="hint" id="hint">输入关键词实时搜索</div>
<div class="results" id="results"></div>

<script src="search_index.json" type="application/json"></script>
<script>
let index = [];
fetch('search_index.json')
  .then(r => r.json())
  .then(data => { index = data; });

const q = document.getElementById('q');
const results = document.getElementById('results');
const hint = document.getElementById('hint');

function escape(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function highlight(text, term) {
  if (!term) return escape(text);
  const re = new RegExp(term.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'), 'gi');
  return escape(text).replace(re, '<em>$&</em>');
}

function search(term) {
  term = term.trim().toLowerCase();
  if (!term) { results.innerHTML = ''; hint.style.display = 'block'; return; }
  hint.style.display = 'none';
  const words = term.split(/\s+/);
  const matches = index.filter(item => {
    const haystack = (item.title + ' ' + item.text + ' ' + item.category).toLowerCase();
    return words.every(w => haystack.includes(w));
  }).slice(0, 15);

  if (matches.length === 0) {
    results.innerHTML = '<div class="empty">没有找到匹配结果</div>';
    return;
  }
  results.innerHTML = matches.map(m => `
    <a class="result" href="${m.slug}.html">
      <div class="result-title">${highlight(m.title, term)}</div>
      <div class="result-cat">${m.category}</div>
      <div class="result-text">${highlight(m.text.slice(0, 120), term)}…</div>
    </a>
  `).join('');
}

q.addEventListener('input', () => search(q.value));
</script>
</body>
</html>
